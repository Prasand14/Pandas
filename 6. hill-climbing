def climb_hill(n):
  if n <= 2:
    return n
  first, second = 1, 2
  for i in range(3, n+1):
    # The current step is the sum of the previous two
    current = first + second
    # Move forward: the old 'second' becomes 'first'
    first = second
    second = current
  
  return second
