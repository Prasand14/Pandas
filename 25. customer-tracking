import pandas as pd

def total_active_hours(cust_tracking):
    
    df = cust_tracking.copy()
    df['timestamp'] = pd.to_datetime(df['timestamp'])
    df = df.sort_values(['user_id', 'timestamp'])
    
    # Shift the timestamp to get the end time for each start state
    df['session_end'] = df.groupby('user_id')['timestamp'].shift(-1)
    
    # 3. Filter for session starts (state=1)
    active_sessions = df[df['state'] == 1].copy()
    
    # 4. Calculate duration in hours
    active_sessions['hours'] = (active_sessions['session_end'] - active_sessions['timestamp']).dt.total_seconds() / 3600
    
    # 5. Aggregate by user
    result = active_sessions.groupby('user_id')['hours'].sum().reset_index()
    
    return result
