def convert_to_base_13(num):
    # Edge Case
    if num == 0:
        return "0"
    
    # Handle negative numbers if necessary
    is_negative = num < 0
    num = abs(num)
    
    # Define the base 13 digits
    digits = "0123456789ABC"
    result = []
    
    while num > 0:
        # Get the remainder
        remainder = num % 13
        result.append(digits[remainder])
        
        # Get the new quotient for the next iteration
        num //= 13
        
    # Reverse the list and join to form the final string
    base_13_str = "".join(reversed(result))
    
    return "-" + base_13_str if is_negative else base_13_str
