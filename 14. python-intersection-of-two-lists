def intersection(a, b):
  ip1_list = []
  ip2_list = []
  ot_list = []
  
  if len(a) > len(b):
    ip1_list = b
    ip2_list = a
  else:
    ip1_list = a
    ip2_list = b
    
  for i in  ip1_list:
    if i in ip2_list:
      ot_list.append(i)
  
  return ot_list
