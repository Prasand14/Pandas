def max_satisfaction(expectations, cards):
  expectations.sort()
  cards.sort()
  
  satisfied_count = 0
  teammate_ptr = 0
  card_ptr = 0
  
  while teammate_ptr < len(expectations) and card_ptr < len(cards):
    if cards[card_ptr] >= expectations[teammate_ptr]:
      satisfied_count += 1
      teammate_ptr += 1
      card_ptr += 1
    else:
      card_ptr += 1
  
  return satisfied_count
