def spiral_order(matrix):
    if not matrix: return []
    
    res = []
    top, bottom = 0, len(matrix) - 1
    left, right = 0, len(matrix[0]) - 1
    
    while top <= bottom and left <= right:
        # 1. Traverse Right (along the current 'top' row)
        for i in range(left, right + 1):
            res.append(matrix[top][i])
        top += 1 # The top row is finished!
        
        # 2. Traverse Down (along the current 'right' column)
        for i in range(top, bottom + 1):
            res.append(matrix[i][right])
        right -= 1 # The right column is finished!
        
        # Check if boundaries crossed before going Left/Up
        if not (top <= bottom and left <= right):
            break
            
        # 3. Traverse Left (along the current 'bottom' row)
        for i in range(right, left - 1, -1):
            res.append(matrix[bottom][i])
        bottom -= 1 # The bottom row is finished!
        
        # 4. Traverse Up (along the current 'left' column)
        for i in range(bottom, top - 1, -1):
            res.append(matrix[i][left])
        left += 1 # The left column is finished!
        
    return res
